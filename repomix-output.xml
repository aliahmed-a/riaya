class RiayaApp extends ConsumerWidget {
  const RiayaApp({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final router = ref.watch(routerProvider);
    final themeMode = ref.watch(themeModeProvider); // 🟢 WATCH THE THEME PROVIDER

    return MaterialApp.router(
      title: 'RIAYA Medical Complex',
      debugShowCheckedModeBanner: false,
      routerConfig: router,
      theme: AppTheme.lightTheme,
      darkTheme: AppTheme.darkTheme,
      themeMode: themeMode, // 🟢 UPDATED THIS
    );
  }
}
